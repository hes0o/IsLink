{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgreSQL": "Host=your-neon-host.neon.tech;Database=islink;Username=your_username;Password=your_password;SSL Mode=Require;Trust Server Certificate=true",
    "MongoDB": "mongodb+srv://username:password@cluster.mongodb.net/islink?retryWrites=true&w=majority"
  },
  "JwtSettings": {
    "Secret": "your-super-secret-jwt-key-make-it-at-least-32-characters-long",
    "Issuer": "IsLink.API",
    "Audience": "IsLink.Client",
    "ExpirationInDays": 7
  },
  "CorsSettings": {
    "AllowedOrigins": ["http://localhost:5173", "http://localhost:3000"]
  }
}

